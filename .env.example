# =============================================================================
# Counted — local development environment
# Copy this file to `.env.local` (gitignored) and fill in the values.
# NEVER commit real keys to the repo. Use your hosting provider's secret
# manager for production.
# =============================================================================


# ---- Database (Neon) ----
# From the Neon dashboard → Connection Details → "Pooled connection".
# The `?sslmode=require` flag is required for Neon.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require


# ---- Better Auth ----
# Generate a secret with: openssl rand -base64 32
# Min 32 chars. Used to sign session cookies and CSRF tokens.
BETTER_AUTH_SECRET=

# The public origin of the app. In dev: http://localhost:3000
# In prod: https://your-domain.com
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000


# ---- Stripe (server-side ONLY — never prefix with NEXT_PUBLIC_) ----
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=


# ---- Arcjet (rate limiting) ----
ARCJET_KEY=
